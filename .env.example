# Backend — set these as server environment variables or in a .env file
# loaded by your web server / process manager.

DB_HOST=127.0.0.1
DB_NAME=ishis
DB_USER=ishis_app
DB_PASS=CHANGE_ME

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Random secret for signing auth tokens — generate with: php -r "echo bin2hex(random_bytes(32));"
AUTH_SECRET=CHANGE_ME_IN_PRODUCTION

# Used by install.php to set the initial admin password non-interactively
ADMIN_PASSWORD=

# Frontend — prefix with VITE_ so Vite exposes them to the client bundle
VITE_API_BASE_URL=http://localhost/HICT-22013-Hospital-Management-System/backend/api.php
